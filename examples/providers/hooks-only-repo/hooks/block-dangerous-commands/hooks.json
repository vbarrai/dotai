{
  "hooks": {
    "block-dangerous-commands": {
      "description": "Prevents rm -rf and other destructive commands",
      "claude-code": {
        "PreToolUse": [
          {
            "matcher": "Bash",
            "hooks": [
              {
                "type": "command",
                "command": "echo 'Checking for dangerous commands...'"
              }
            ]
          }
        ]
      },
      "cursor": {
        "onSave": [
          {
            "matcher": "**/*.sh",
            "hooks": [
              {
                "type": "command",
                "command": "echo 'Validating shell script...'"
              }
            ]
          }
        ]
      }
    }
  }
}
